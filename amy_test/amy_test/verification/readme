  ros2 launch amy_test latency_monitoring.launch.py
  
  # Live dashboard
  ros2 launch amy_test latency_monitoring.launch.py mode:=dashboard
  
  # Automated test (30s)
  ros2 launch amy_test latency_monitoring.launch.py mode:=test

